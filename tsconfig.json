{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "types": ["node"]
  },
  "include": [],
  "references": [
    { "path": "packages/core" },
    { "path": "packages/gui" },
    { "path": "packages/server" },
    { "path": "packages/sdk-ts" },
    { "path": "packages/cli" },
    { "path": "packages/mcp-glove" }
  ]
}
